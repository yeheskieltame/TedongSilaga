# Deployer private key (without 0x prefix)
# Generate: cast wallet new
# Get address: cast wallet address --private-key <key>
DEPLOYER_PRIVATE_KEY=

# Chainlink CRE Forwarder address (this is the RESOLVER that calls resolveMarket)
# Source: https://docs.chain.link/cre/guides/workflow/using-evm-client/forwarder-directory-go
#
# World Chain Sepolia (simulation): 0x6E9EE680ef59ef64Aa8C7371279c27E496b5eDc1
# World Chain Sepolia (production): 0x76c9cf548b4179F8901cda1f8623568b58215E62
# World Chain Mainnet (simulation): 0x6E9EE680ef59ef64Aa8C7371279c27E496b5eDc1
# World Chain Mainnet (production): 0x98B8335d29Aca40840Ed8426dA1A0aAa8677d8D1
RESOLVER_ADDRESS=0x6E9EE680ef59ef64Aa8C7371279c27E496b5eDc1

# Platform fee wallet (receives 1% fee)
# Use your own wallet address
PLATFORM_WALLET=

# Cultural preservation fund wallet (receives 1% fee)
# Use your own wallet address (or a separate multisig for production)
CULTURAL_FUND_WALLET=

# ERC-20 token address (MockUSDC / WLD / USDC)
# Deploy MockUSDC first: forge script script/DeployToken.s.sol:DeployToken --rpc-url $RPC_URL --broadcast
# Then paste the deployed address here
TOKEN_ADDRESS=

# RPC URL
# World Chain Sepolia: https://worldchain-sepolia.g.alchemy.com/v2/YOUR_KEY
# World Chain Mainnet: https://worldchain-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL=

# Etherscan/Worldscan API key (for contract verification)
ETHERSCAN_API_KEY=
